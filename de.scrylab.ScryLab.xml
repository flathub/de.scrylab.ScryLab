<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">

  <!-- MDF4 / MF4 - ASAM MDF Version 4.x -->
  <mime-type type="application/x-mf4">
    <comment>MDF4 measurement data file</comment>
    <comment xml:lang="de">MDF4 Messdatendatei</comment>
    <glob pattern="*.mf4"/>
    <glob pattern="*.MF4"/>
    <icon name="de.scrylab.ScryLab"/>
    <generic-icon name="text-x-generic"/>
  </mime-type>

  <!-- MDF3 / MF3 - ASAM MDF Version 3.x -->
  <mime-type type="application/x-mf3">
    <comment>MDF3 measurement data file</comment>
    <comment xml:lang="de">MDF3 Messdatendatei</comment>
    <glob pattern="*.mf3"/>
    <glob pattern="*.MF3"/>
    <icon name="de.scrylab.ScryLab"/>
    <generic-icon name="text-x-generic"/>
  </mime-type>

  <!-- Generic MDF (fallback for .mdf extension) -->
  <mime-type type="application/x-mdf">
    <comment>MDF measurement data file</comment>
    <comment xml:lang="de">MDF Messdatendatei</comment>
    <sub-class-of type="application/x-mf3"/>
    <icon name="de.scrylab.ScryLab"/>
    <generic-icon name="text-x-generic"/>
  </mime-type>

  <!-- ScryLab project files -->
  <mime-type type="application/x-scrylab-project">
    <comment>ScryLab project</comment>
    <comment xml:lang="de">ScryLab-Projekt</comment>
    <glob pattern="*.scrylab"/>
    <icon name="de.scrylab.ScryLab"/>
    <generic-icon name="application-x-executable"/>
  </mime-type>

</mime-info>
